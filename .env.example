# ── Langflow ──────────────────────────────────────────────────────────────────
# After running docker-compose up, open http://localhost:7860
# Import langflow_flow.json, copy the Flow ID from the URL, paste below.
LANGFLOW_FLOW_ID=your-flow-id-here
LANGFLOW_API_KEY=your-langflow-api-key-here   # leave blank if auto-login enabled

# ── IBM watsonx (for Granite Coach in Next.js frontend) ───────────────────────
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-project-id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── Backend URL (used by Next.js frontend) ────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
